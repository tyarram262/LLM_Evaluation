# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Judge model + generation limits
MODEL_ID=gemini-2.0-flash
MAX_TOKENS=1024
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Database. Local default is async SQLite; production should use Postgres, e.g.
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./evaluations.db

# Client API keys (comma-separated bearer tokens) and per-key rate limit
API_KEYS=dev-local-key
RATE_LIMIT=60/minute
